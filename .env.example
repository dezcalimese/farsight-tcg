# Copy to .env and fill in what you have. Nothing here is required to run
# the app locally — any source without credentials falls back to a stub so
# the pipeline still runs end-to-end with partial (fake) data.

# --- Core ---
ENV=development
DATABASE_URL=postgresql+asyncpg://farsight:farsight@localhost:5432/farsight
REDIS_URL=redis://localhost:6379/0

# --- TCGPlayer (price source) ---
# https://docs.tcgplayer.com/docs/getting-started — apply for API access
TCGPLAYER_CLIENT_ID=
TCGPLAYER_CLIENT_SECRET=

# --- Discord (restock source) ---
# Create a bot at https://discord.com/developers/applications, invite it
# read-only to the restock channel(s) you want watched, then list channel
# IDs (comma-separated) here.
DISCORD_BOT_TOKEN=
DISCORD_RESTOCK_CHANNEL_IDS=

# --- News (RSS) — no key needed, override if you want different feeds ---
# PokeBeach and the official Pokemon.com feed are currently behind bot-detection
# challenges (Cloudflare/Incapsula); we don't bypass those, so r/PokemonTCG is
# the working default. Swap in PokeBeach/official feeds here if they open back up.
NEWS_RSS_FEEDS=https://www.reddit.com/r/PokemonTCG/.rss

# --- Delivery (not used until Phase 2) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
DISCORD_WEBHOOK_URL=
